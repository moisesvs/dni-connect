# ============================================
# Configuración de Supabase MCP
# ============================================

# URL del proyecto Supabase
# Obtén esto desde https://app.supabase.com/project/[project-id]/settings/api
SUPABASE_URL=https://xxxxx.supabase.co

# Clave API anon (para cliente)
# Usa esta clave en la app frontend
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave API service_role (para servidor)
# CUIDADO: Solo usa esto en el servidor, nunca en el cliente
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Configuración opcional
SUPABASE_REDIRECT_URL=http://localhost:3000
SUPABASE_DEBUG=false
SUPABASE_TIMEOUT=30000

# Buckets de Storage (crear estos en Supabase Console)
SUPABASE_STORAGE_BUCKET_AVATARS=avatars
SUPABASE_STORAGE_BUCKET_DOCUMENTS=documents
SUPABASE_STORAGE_BUCKET_PHOTOS=photos
