# ============================================
# Configuración de Google NotebookLM MCP
# ============================================

# API Key de Google NotebookLM
# Obtén esto desde https://notebooklm.google.com/settings
NOTEBOOKLM_API_KEY=

# ID del Notebook principal (opcional)
# Puedes tener múltiples notebooks, especifica el que deseas usar por defecto
NOTEBOOKLM_NOTEBOOK_ID=8f79890a-531b-4b8f-8f09-d98fe6b60bbc

# Configuración de exportación
NOTEBOOKLM_EXPORT_FORMAT=markdown
NOTEBOOKLM_EXPORT_PATH=./docs/notebooklm-exports

# Opciones de generación
NOTEBOOKLM_PODCAST_VOICE=natural
NOTEBOOKLM_STUDY_GUIDE_FORMAT=markdown
NOTEBOOKLM_OUTLINE_FORMAT=json

# Configuración de sincronización
NOTEBOOKLM_AUTO_SYNC=true
NOTEBOOKLM_SYNC_INTERVAL=3600000  # 1 hora en milisegundos
NOTEBOOKLM_DEBUG=false
