{
  "watch": ["src"],
  "ext": "ts,json",
  "ignore": ["node_modules/**", "dist/**", "*.test.ts"],
  "delay": "1000",
  "exec": "npm run start",
  "env": {
    "NODE_ENV": "development",
    "LOG_LEVEL": "debug"
  },
  "events": {
    "restart": "echo '🔄 Backend restarting...'",
    "crash": "echo '❌ Backend crashed'",
    "quit": "echo '✅ Backend stopped'"
  }
}
