# Backend
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-secure-jwt-secret-change-in-production
JWT_EXPIRY=15m

# Google Cloud
GOOGLE_CLOUD_PROJECT=dni-connect
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIRESTORE_COLLECTION=verifications
GCS_BUCKET=dni-connect-documents

# PKI
PKI_CERTIFICATE_URL=http://pki.policia.es/cnp/MiDNI
OCSP_RESPONDER_URL=http://ocsp.policia.es

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
