{
  "name": "dni-connect",
  "version": "1.0.0",
  "private": true,
  "description": "Solución multiplataforma para verificación de identidad mediante DNIe (NFC) y QR MiDNI",
  "workspaces": [
    "packages/*",
    "apps/web/frontend",
    "apps/web/backend"
  ],
  "scripts": {
    "dev:web": "npm run dev:backend",
    "dev:frontend": "echo 'No frontend web configurado'",
    "dev:backend": "npm run dev --workspace=apps/web/backend",
    "dev:watch": "./watch.sh all web",
    "dev:flutter:watch": "./watch.sh flutter web",
    "dev:backend:watch": "./watch.sh backend",
    "build:core": "npm run build --workspace=packages/core",
    "build:frontend": "npm run build --workspace=apps/web/frontend",
    "build:backend": "npm run build --workspace=apps/web/backend",
    "build:all": "npm run build:core && npm run build:backend",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
